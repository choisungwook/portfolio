# --- Project Configuration ---
aws_region   = "ap-northeast-2"
project_name = "eks-custom-ami"

# --- EKS Configuration ---
eks_cluster_name = "eks-custom-ami-1-35"
eks_version      = "1.35"

# EKS 접근 유형
endpoint_private_access = true
# public_access가 false이면, terraform apply를 실행한 host가 private subnet에 접근 가능해야 합니다.
endpoint_public_access = true

# EKS auto mode
auto_mode_enabled      = false
cluster_compute_config = {}

custom_ami_id = ""
