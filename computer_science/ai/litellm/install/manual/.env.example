# 실제 값을 채운 뒤 .env로 복사한다. .env는 커밋하지 않는다.
# 깡통 gateway는 provider API key 없이 뜬다. 아래 필수 값만 채우면 된다.

# gateway 관리자 key. virtual key 발급·조회에 쓴다. sk- 로 시작해야 한다.
LITELLM_MASTER_KEY=sk-master-change-me

# DB에 저장하는 key를 암호화하는 salt. 한 번 정하면 바꾸지 않는다.
LITELLM_SALT_KEY=salt-change-me

# Postgres 비밀번호
POSTGRES_PASSWORD=litellm-change-me

# 관리 콘솔(/ui) 로그인 계정. ../../docs/7-web-ui.md 실습에서 쓴다.
UI_USERNAME=admin
UI_PASSWORD=admin-change-me

# provider API key는 .env에 두지 않는다. 웹 UI에서 모델을 추가할 때 폼에 붙여 넣으면
# gateway가 LITELLM_SALT_KEY로 암호화해 DB에 저장한다. 절차: ../../docs/manual/web-ui-setup.md
