OPENAI_API_KEY=

# 2026-05 기준 OpenAI 최신 주력 모델은 gpt-5.5, GPT-5.4 mini, GPT-5.4 nano, GPT-5 nano
OPENAI_CHAT_MODEL=gpt-5-nano

# RAG 검색에는 문서와 질의를 같은 embedding model로 변환해야 한다.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

RAG_TOP_K=5

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
# 사용하려면 true로 설정
LANGSMITH_TRACING=false
LANGSMITH_PROJECT={your project name}
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Fine-tuning notebook
HF_BASE_MODEL=meta-llama/Meta-Llama-3-8B
FINE_TUNE_TRAIN_FILE=data/loyalty_qa_train.jsonl
FINE_TUNE_EVAL_FILE=data/loyalty_qa_val.jsonl
