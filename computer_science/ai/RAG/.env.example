OPENAI_API_KEY=

# 2026-05 기준 OpenAI 최신 주력 모델은 gpt-5.5, GPT-5.4 mini, GPT-5.4 nano, GPT-5 nano
OPENAI_CHAT_MODEL=gpt-5-nano

# RAG 검색에는 문서와 질의를 같은 embedding model로 변환해야 한다.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

RAG_TOP_K=5

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
# 사용하려면 true로 설정
LANGSMITH_TRACING=false
LANGSMITH_PROJECT={your project name}
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Fine-tuning notebook
# LM Studio에서 다운로드한 MLX 모델을 사용할 때는 로컬 절대경로를 넣는다.
HF_BASE_MODEL=/absolute/path/to/your/lmstudio/models/lmstudio-community/Qwen2.5-0.5B-Instruct-MLX-4bit
# 이 디렉터리에 train.jsonl, valid.jsonl, test.jsonl을 둔다.
FINE_TUNE_DATA_DIR=data/loyalty_qa_mlx
FINE_TUNE_ADAPTER_DIR=outputs/qwen25-05b-myelite-adapter
FINE_TUNE_MAX_ITERS=80
FINE_TUNE_BATCH_SIZE=1
FINE_TUNE_NUM_LAYERS=4
FINE_TUNE_REPORT_TO=none
FINE_TUNE_TEST_PROMPT=[MyElite Loyalty Program FAQ]: What is the cost of the MyElite Loyalty Program?
WANDB_PROJECT=chapter4-finetuning
WANDB_API_KEY=
