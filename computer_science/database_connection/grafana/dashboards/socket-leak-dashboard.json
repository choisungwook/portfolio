{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Process Open FDs (앱 측 FD 누수 지표)",
      "description": "JVM 프로세스의 열린 파일 디스크립터 수. /reproduce 호출마다 계단식으로 증가하면 소켓 FD가 누수되고 있는 것이다.",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "process_open_fds{application=\"socket-leak\"}",
          "legendFormat": "open_fds (현재)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "process_max_fds{application=\"socket-leak\"}",
          "legendFormat": "max_fds (한계)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Zombie Connections (MariaDB 서버 좀비 수)",
      "description": "MariaDB에서 SELECT SLEEP을 실행 중인 좀비 커넥션 수. 앱에서는 이미 예외가 발생했는데도 MariaDB에서 쿼리가 실행 중이면 소켓이 닫히지 않은 것이다.",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "mariadb_zombie_connections{application=\"socket-leak\"}",
          "legendFormat": "zombie connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Socket Leak 총 횟수 (/reproduce 호출 누적)",
      "description": "/reproduce 엔드포인트 호출 누적 횟수.",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "mariadb_socket_leak_total{application=\"socket-leak\"}",
          "legendFormat": "total leaks",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "FD 소진율 (%)",
      "description": "현재 열린 FD / 최대 FD 비율. 이 값이 오르면 FD 고갈이 임박한 것이다.",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "100 * process_open_fds{application=\"socket-leak\"} / process_max_fds{application=\"socket-leak\"}",
          "legendFormat": "fd_usage_%",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM 메모리 사용량",
      "description": "JVM heap/non-heap 메모리 사용량 추이. 소켓 누수가 지속되면 관련 버퍼도 영향을 받는다.",
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "sum by (area) (jvm_memory_used_bytes{application=\"socket-leak\"})",
          "legendFormat": "{{area}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["mariadb", "socket-leak", "fd", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MariaDB Socket Leak Monitoring",
  "uid": "socket-leak-dashboard",
  "version": 1,
  "weekStart": ""
}
